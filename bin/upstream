#!/usr/bin/env python
"""
- Searches for a topic on StackOverflow.
- Picks an answered or highest voted question.
- Fetches RSS feed of the question.
- Renders answers in markdown.
All errors written to stderr, result to stdout.
Output is rendered as code.

Configurable through environment variables:
- LOG_LEVEL: valid python loglevel name, e.g.: DEBUG, INFO, NOSET, etc.
- UPSTREAM_RSS_CACHE: cache rss response (as json, cached by question id.)
- UPSTREAM_REQ_CACHE: cache query_search_api response (as json, cached by tag + query_search_api query.)
- UPSTREAM_DIR_CACHE: where to store cache, defaults to system temporary directory.

Issues:
- Basic text wrapping, cht.sh requires it to be length of <=70, breaks markdown links.
- cht.sh itself breaking it by forcefully wrapping a long link without ouputting the line as a comment. Example:
    ```
    [here in a github repo](https://github.com/schmijos/html-table-parser-python3/blob/master/html_table_parser/parser.py)
    ```
    output:
    ```
    [here in a github
    # repo](https://github.com/schmijos/html-table-parser-
    python3/blob/master/html_table_parser/parser.py)
    ```
  First break is issue without our logic, the second is cht.sh limitation.
"""

import typing
import sys
import time
import logging
import os
import tempfile
import json
import pathlib

import feedparser
import requests
from markdownify import markdownify as md


FALSY = ["", "n", "no", "false"]
UPSTREAM_LOG_LEVEL = os.getenv("UPSTREAM_LOG_LEVEL", "WARNING")
UPSTREAM_RSS_CACHE = os.getenv("UPSTREAM_RSS_CACHE", "").lower() not in FALSY
UPSTREAM_REQ_CACHE = os.getenv("UPSTREAM_REQ_CACHE", "").lower() not in FALSY
UPSTREAM_DIR_CACHE = os.getenv("UPSTREAM_DIR_CACHE", tempfile.tempdir)
LANG_TO_COMMENT = {
    "python": "#",
    "lua": "--",
}  # // for everything else
LINE_MAX_LENGTH = 60


SEARCH_URL = "https://api.stackexchange.com/2.3/search"
logger = logging.getLogger(__name__)
logging.basicConfig(
    format='time="%(asctime)s" level="%(levelname)s" func="%(funcName)s" line="%(lineno)d" message="%(message)s"',
    level=getattr(logging, UPSTREAM_LOG_LEVEL),
)


class SearchOwnerDict(typing.TypedDict):
    account_id: int
    reputation: int
    user_id: int
    # literal: registered, ...?
    user_type: str
    profile_image: str
    display_name: str
    # link to profile
    link: str


class SearchItemDict(typing.TypedDict):
    tags: list[str]
    owner: SearchOwnerDict
    is_answered: bool
    view_count: int
    answer_count: int
    score: int
    last_activity_date: int
    creation_date: int
    question_id: int
    content_license: str
    link: str
    title: str


class SearchResultDict(typing.TypedDict):
    items: list[SearchItemDict]


class RSSEntryReRankDict(typing.TypedDict):
    # invalid parsing, lost tag value.
    scheme: str


class RSSEntryFieldDetailDict(typing.TypedDict):
    type: typing.Literal["text/plain", "text/html", "text/md"]
    language: typing.Optional[str]
    base: str
    value: str


class RSSEntryTagDict(typing.TypedDict):
    term: str
    scheme: str
    label: typing.Optional[str]


class RSSEntryAuthorDict(typing.TypedDict):
    name: str
    href: str


class RSSEntryLinkDict(typing.TypedDict):
    rel: str
    href: str
    type: typing.Literal["text/html"]


class RSSEntryDict(typing.TypedDict):
    id: str
    guidislink: bool
    link: str
    re_rank: RSSEntryReRankDict
    title: str
    title_detail: RSSEntryFieldDetailDict
    tags: list[RSSEntryTagDict]
    authors: list[RSSEntryAuthorDict]
    authors_detail: list[RSSEntryAuthorDict]
    href: str
    author: str
    links: list[RSSEntryLinkDict]
    published: str
    published_parsed: time.struct_time
    summary: str
    summary_detail: RSSEntryFieldDetailDict


class RSSQuestionFeedDict(typing.TypedDict):
    bozo: bool
    entries: list[RSSEntryDict]


def query_question_rss(question_url: str) -> list[RSSEntryDict]:
    """
    Converts a regular link to a question on StackOverflow to RSS feed URL and fetches it.
    In addition `summary_detail` value of every answer will be converted to Markdown.
    You still have original body inside `entries[].summary`.
    """
    # /questions/[id]/[slug] -> /feeds/question/[id]
    url = question_url.replace("/questions", "/feeds/question").rsplit("/", 1)[0]
    logger.info("url=%s", url)
    id_ = url.rsplit("/", 1)[-1]

    cache = (
        pathlib.Path(os.path.join(UPSTREAM_DIR_CACHE, f"{id_}.json"))
        if UPSTREAM_RSS_CACHE and UPSTREAM_DIR_CACHE
        else None
    )
    if cache and cache.exists():
        logger.info("cache=%s", cache)
        return typing.cast(RSSQuestionFeedDict, json.loads(cache.read_bytes()))[
            "entries"
        ]

    response = typing.cast(RSSQuestionFeedDict, feedparser.parse(url))
    logger.info("len(response['entries'])=%s", len(response["entries"]))
    for item in response["entries"]:
        summary = md(item["summary"])
        item["summary_detail"]["value"] = summary
        item["summary_detail"]["type"] = "text/md"

    if cache is not None and len(response["entries"]):
        cache.parent.mkdir(exist_ok=True)
        cache.write_text(json.dumps(response))

    return response["entries"]


def parse_q(q: str) -> tuple[str, str]:
    """
    User search term parser. Replaces `+` signs with spaces, mostly for interoperability
    when called manually from command line.
    :param q: term as `Question` adapter passes it: "[lang]/[topic] more keywords"
    :returns: `lang`, `topic more keywords`.
    :raises Exception: when query is empty.
    """
    lang, query = "", ""
    p = q.split(" ", 1)
    if not p[0]:
        raise Exception("No question provided.")
    lang = p[0]

    if "/" in lang:
        lang, *p = q.split("/")
        query = " ".join(p)

    if len(p) == 2:
        query += p[1]

    query = query.replace("+", " ")
    return lang, query


def query_search_api(q: str) -> tuple[list[SearchItemDict], str, str]:
    """
    Requests StackOverflow /search API.
    :raises Exception: on connection errors or bad response.
    :returns: list of found questions, tag and term used for search.
    """
    logger.info("q=%s", q)
    lang, query = parse_q(q)
    logger.info("tagged=%s intitle=%s", lang, query)

    cache = (
        pathlib.Path(
            os.path.join(UPSTREAM_DIR_CACHE, f"{lang}_{query}.json".replace(" ", "_"))
        )
        if UPSTREAM_REQ_CACHE and UPSTREAM_DIR_CACHE
        else None
    )
    if cache and cache.exists():
        logger.info("cache=%s", cache)
        return (
            typing.cast(SearchResultDict, json.loads(cache.read_bytes()))["items"],
            lang,
            query,
        )

    response = requests.get(
        SEARCH_URL,
        params={
            "order": "desc",
            "sort": "votes",
            "tagged": lang,
            "intitle": query,
            "site": "stackoverflow",
        },
    )
    response.raise_for_status()
    logger.info("response.request.url=%s", response.request.url)

    data = typing.cast(SearchResultDict, response.json())
    if cache is not None and len(data["items"]):
        cache.parent.mkdir(exist_ok=True)
        cache.write_text(json.dumps(data))
    return data["items"], lang, query


def _render_sentence_chunks(
    text: str,
    comment_prefix: str,
    max_length: int,
) -> typing.Generator[str]:
    """
    render helper, wraps text to stay within `max_length`, each
    outputted line is prefixed by `comment_prefix`.
    """
    chunks: list[str] = []
    for word in text.split(" "):
        next_chunk = " ".join(chunks + [word])
        if len(next_chunk) + len(comment_prefix) > max_length:
            yield f"{comment_prefix} {' '.join(chunks)}"
            chunks = [word]
        else:
            chunks.append(word)
    if rest := " ".join(chunks):
        yield f"{comment_prefix} {rest}"


def render(text: str, comment_prefix: str) -> typing.Generator[str]:
    """
    A simple renderer converting markdown to code by prefixing all
    lines outside code blocks with `comment_prefix` and stripping code blocks.
    Example:
        Hello world in python:
        ```
        print("Ssssss")
        ```
    Output:
        # Hello world in python:
        print("Ssssss")
    Also ensures that line not exeding 70 chars. Outputs line by line.
    """
    code_block = False
    for line in text.split("\n"):
        if line == "```":
            if code_block:
                yield f"{comment_prefix} " + "-" * LINE_MAX_LENGTH + "\n\n"
            code_block = not code_block
            continue
        if code_block:
            yield line
        else:
            yield from _render_sentence_chunks(line, comment_prefix, LINE_MAX_LENGTH)


def main(q: str) -> typing.Generator[str]:
    """
    :param q: user's query, in form "[lang]/topic more keywords".
    :returns: parsed answer in form of the given lang code, line by line.
    """

    # search for question, use lang as question tag, the rest is search query.
    # example: "python/parsing html" will search questions with "python" tag and "parsing html" in title.
    results, lang, _ = query_search_api(q)
    logger.info("len(results)=%s lang=%s", len(results), lang)

    if not results:
        raise Exception("No results on stackoverflow")

    # query_search_api returns results sorted by vote,
    # default to any highest voted question, but if there
    # an answered question - take it instead.
    question = results[0]
    for i in results:
        if i["is_answered"]:
            question = i
            break

    # this will fetch answers using rss feed,
    # doesn't seem that API have a better way to do it.
    # another option is to use `lynx -dump` and parse it.
    answers = query_question_rss(question["link"])[1:]
    comment_prefix = LANG_TO_COMMENT.get(lang, "//")
    for answer in answers:
        # title contains who answered and short summary.
        # summary_detail answer itself, note original summary_detail is html,
        # but query_question_rss converts it to md, easier to work with.
        yield from render(answer["title"], comment_prefix)
        yield from render(answer["summary_detail"]["value"], comment_prefix)


if __name__ == "__main__":
    args = sys.argv[1:]
    try:
        for line in main("".join(args)):
            sys.stdout.write(line + "\n")
    except Exception as e:
        sys.stderr.write(str(e) + "\n")
